import java.util.*;
public class Main{
public static void main(String[] args){
int[] arr = {1, 0, 5, 0, 3, 7, 0, 2};
int[] result = new int[arr.length];
int index = 0;


for (int i = 0; i < arr.length; i++) {
    if (arr[i] != 0) {
        result[index] = arr[i];
        index++;
    }
}


for (int i = 0; i < arr.length; i++) {
    if (arr[i] == 0) {
        result[index] = 0;
        index++;
    }
}


for (int i = 0; i < result.length; i++) {
    System.out.print(result[i] + " ");
}
}
}
