import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        System.out.println("Even numbers are :                Odd numbers are :");
        for(int i=0;i<=n;i++){
            for(int j=0;i<=n;i++){
                if(i%2==0 && j%2==0){
                System.out.println(i+"     "+j);
                }
            }
            
        }

        sc.close();
    }
}
