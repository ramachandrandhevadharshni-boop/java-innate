import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        ArrayList<Integer> x=new ArrayList();
        for(int i=0;i<n;i++){
            if(i%2!=0){
            x.add(i);
        }}
        System.out.print(x);
    }
}
