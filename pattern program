import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.print("Enter size : ");
       int n=sc.nextInt();
       for(int i=0;i<2;i++){
           for(int j=0;j<2;j++){
               System.out.print(((i+j)%n)+" ");
           }
           System.out.println();
       }
       
       
    }
}
